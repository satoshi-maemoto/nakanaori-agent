# Google Cloud TTS — .env への追記例
# 詳細: docs/google-cloud-tts-setup.md
#
# 方法 A（推奨）: サービスアカウント JSON ファイルへのパス
GOOGLE_APPLICATION_CREDENTIALS=./config/google-tts-service-account.json

# 方法 B: JSON を 1 行で直接指定（Cloud Run シークレット等向け）
# private_key 内の改行は \n にエスケープすること
# GOOGLE_TTS_CREDENTIALS_JSON={"type":"service_account","project_id":"YOUR_GCP_PROJECT_ID","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"nakanaori-tts@YOUR_GCP_PROJECT_ID.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}

# 任意: 音声（デフォルト ja-JP-Chirp3-HD-Rasalgethi）
# GOOGLE_TTS_VOICE=ja-JP-Chirp3-HD-Rasalgethi
