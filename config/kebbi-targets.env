# Kebbi API 接続先（scripts/kebbi-target.sh）
# .env で KEBBI_TARGET 等を上書き可能

# staging | local
KEBBI_TARGET=staging

# ステージング Web URL（API は nakanaori-web → nakanaori-api に自動変換）
KEBBI_STAGING_WEB_URL=https://nakanaori-web-370062202060.asia-northeast1.run.app

# 明示指定する場合のみ（通常は空で OK）
# KEBBI_STAGING_API_URL=https://nakanaori-api-370062202060.asia-northeast1.run.app

# ローカル dev-stack（LAN IP は kebbi-target.sh が自動検出）
KEBBI_LOCAL_PORT=8080
# KEBBI_LOCAL_API_URL=http://192.168.11.4:8080
