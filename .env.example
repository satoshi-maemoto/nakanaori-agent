# Nakanaori — ローカル開発用環境変数
#
# 使い方:
#   cp .env.example .env
#   # .env に API キー等を記入
#   bash scripts/dev-stack.sh
#
# GEMINI_API_KEY 未設定時は LLM スタブ（デモ用固定応答）で動作します。

# --- Gemini / ADK（packages/agents → API 経由）---
# 取得: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# 任意（デフォルト: gemini-2.5-flash）
# GEMINI_MODEL=gemini-2.5-flash

# isLlmEnabled() でも参照可（ADK 本体は GEMINI_API_KEY 推奨）
# GOOGLE_GENAI_API_KEY=

# --- API サーバー（services/api）---
PORT=8080

# --- Google Cloud TTS（packages/tts → POST /v1/tts/synthesize）---
# 手順: docs/google-cloud-tts-setup.md
# サンプル: config/google-tts-service-account.example.json, config/google-tts.env.example
#
# いずれか 1 つを設定（未設定時 TTS API は 503、Kebbi は Nuwa ロボ TTS にフォールバック）
# GOOGLE_APPLICATION_CREDENTIALS=./config/google-tts-service-account.json
# GOOGLE_TTS_CREDENTIALS_JSON={"type":"service_account","project_id":"...",...}
# GOOGLE_TTS_VOICE=ja-JP-Chirp3-HD-Rasalgethi

# --- VRM モデルコピー（scripts/setup-vrm-models.sh）---
# CharaTomo-Web の models ディレクトリ（未設定時は sibling パスを試行）
# CHARATOMO_MODELS=/path/to/AIxR-CharaTomo-Web/src/static/models

# --- Kebbi 実機 API 接続先（scripts/kebbi-deploy.sh / kebbi-use-*.sh）---
# staging | local — 既定 staging（config/kebbi-targets.env 参照）
# KEBBI_TARGET=staging
# KEBBI_STAGING_WEB_URL=https://nakanaori-web-370062202060.asia-northeast1.run.app
# KEBBI_LOCAL_API_URL=http://192.168.11.4:8080

# --- Cloud Run / 本番（参考 — ローカルでは通常不要）---
# SESSION_STORE=memory
# LOG_LEVEL=INFO
